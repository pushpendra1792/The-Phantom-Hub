# Backend - copy to .env and fill in your values
PORT=10000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/phantoms-hub?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=https://your-frontend.vercel.app
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
